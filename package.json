{
  "name": "tic-bot-toe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "pnpm -r --if-present run test",
    "test:core": "pnpm --filter @arena/game-core run test",
    "coverage": "pnpm -r --if-present run coverage",
    "typecheck": "pnpm -r --if-present run typecheck",
    "build": "pnpm -r --if-present run build",
    "dev": "pnpm --filter @arena/web run dev",
    "dev:server": "pnpm --filter @arena/server run dev",
    "assets:prompts": "tsx scripts/gen/preview-prompts.ts",
    "assets:place": "tsx scripts/gen/place-assets.ts",
    "assets:check": "tsx scripts/gen/check-assets.ts",
    "assets:typecheck": "tsc -p scripts/tsconfig.json",
    "daily:check": "tsx scripts/check-daily-pool.ts",
    "smoke:live": "tsx --tsconfig scripts/tsconfig.smoke.json scripts/smoke-live.ts",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.19.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.61.1",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@napi-rs/canvas",
      "@swc/core",
      "sharp"
    ]
  }
}
