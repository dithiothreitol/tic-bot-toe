# Wzor produkcyjnego .env dla ticbottoe.lol.
# Na serwerze: /opt/ticbottoe/deploy/.env  (chmod 600, POZA gitem).
#
# Wygeneruj sekrety:  openssl rand -hex 32

# Haslo do wlasnego Postgresa (kontener ticbottoe-postgres).
POSTGRES_PASSWORD=__wygeneruj__

# Sekret do podpisu sesyjnych JWT (HS256). MUSI byc dlugi i losowy.
JWT_SECRET=__wygeneruj__

# Cloudflare Turnstile — SECRET key (server-side siteverify). NIGDY do gita.
TURNSTILE_SECRET=__z_panelu_cloudflare__

# Publiczny SITE key — wkompilowany w bundle web podczas `docker compose build`.
# Uzywany jako --build-arg; zmiana wymaga PRZEBUDOWY obrazu.
VITE_TURNSTILE_SITE_KEY=__z_panelu_cloudflare__

# Proxy do lokalnego Ollamy (127.0.0.1:11434). Na VPS zostaw false.
ENABLE_OLLAMA=false
