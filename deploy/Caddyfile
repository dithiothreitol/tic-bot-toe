# Caddy reverse proxy with automatic HTTPS (SPEC §3).
# Set DOMAIN (e.g. arena.example.com); Caddy provisions + renews TLS itself.
# Run on the host: `DOMAIN=arena.example.com caddy run --config deploy/Caddyfile`
#
# The app enforces its own security headers (CSP/HSTS/nosniff), so Caddy only
# needs to proxy + compress. Set TRUSTED_PROXY=true so the app trusts XFF.

{$DOMAIN:localhost} {
	encode gzip zstd
	reverse_proxy 127.0.0.1:8080
}

