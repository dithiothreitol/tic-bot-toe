# =============================================================================
# tic-bot-toe / LLM Game Arena — example environment
# Copy to `.env` and fill in. NEVER commit a real `.env`. (see SPEC §16)
# =============================================================================

# --- Backend (apps/server) --------------------------------------------------

# PostgreSQL >= 15, external instance owned by you. App role scoped to its schema.
DATABASE_URL=postgres://arena:arena@localhost:5432/arena

# Cloudflare Turnstile secret (server-side siteverify). Free, host-independent.
# Get one at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# HMAC secret for session JWT (HS256, 30-min TTL). Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Ollama provider on the VPS. Off by default (only provider that spends your CPU).
ENABLE_OLLAMA=false

# Trust X-Forwarded-For for client IP + rate limiting. Only true behind a proxy
# you control (Caddy/nginx). Leave false when the app is directly exposed.
TRUSTED_PROXY=false

# HTTP port for the Hono server (serves API + static frontend on one port).
PORT=8080

# --- Frontend (apps/web, Vite — only VITE_* vars are exposed to the browser) -

# Turnstile SITE key (public, safe to ship). Pairs with TURNSTILE_SECRET above.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Base URL of the backend API. Empty = same origin (default single-port deploy).
VITE_API_BASE=
